{
  "name": "monotheme",
  "version": "0.1.0",
  "type": "module",
  "description": "One source of truth (a VSCode/shiki theme) projected into every tool's native format, switched with one live-reloading command.",
  "license": "MIT",
  "author": "Edu Wass",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduwass/monotheme.git"
  },
  "homepage": "https://github.com/eduwass/monotheme#readme",
  "keywords": [
    "theme",
    "colorscheme",
    "vscode",
    "textmate",
    "shiki",
    "terminal",
    "ansi",
    "dotfiles"
  ],
  "bin": {
    "monotheme": "./src/cli.ts",
    "theme": "./src/cli.ts"
  },
  "scripts": {
    "check": "bun run src/cli.ts check",
    "test": "bun test",
    "embed": "bun scripts/embed-themes.ts",
    "fonts:gen": "bun scripts/gen-font-catalog.ts",
    "fonts:update": "curl -fsSL -o vendor/font-catalogs/programmingfonts.json https://raw.githubusercontent.com/braver/programmingfonts/master/fonts.json && curl -fsSL -o vendor/font-catalogs/nerd-fonts.json https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/bin/scripts/lib/fonts.json && bun scripts/gen-font-catalog.ts",
    "build:binary": "bun scripts/embed-themes.ts && bun scripts/embed-targets.ts && bun scripts/gen-font-catalog.ts && bun build --compile src/cli.ts --outfile dist/theme"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "plist": "^3.1.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "shiki": "^4.2.0"
  }
}
